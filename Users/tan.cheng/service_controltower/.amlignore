# Exclude heavy/local-only folders from Azure ML code upload
.git/
.venv/
venv/
env/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Do not upload raw/enriched data as code artifacts
enriched_data/

# Do not upload generated outputs/logs as code artifacts
data_preparation/output/
output/
outputs/
logs/
*.log

# Do not upload archives and large generated files
*.zip
*.parquet
*.pkl
*.joblib

# Optional local files
.DS_Store
.vscode/

# Added by submit_snapshot_build_aml_job.py to keep AML upload lightweight
data_preparation/aml_run_results/
.aml_job_source/
